    "id": "g5LcDZ2JNpId"
   },
   "source": [
    "## Temperature Scaling \u2014 Calibration Correction\n",
    "\n",
    "Post-hoc calibration by searching for the optimal temperature `T` on the validation set."
   ],
   "id": "g5LcDZ2JNpId"
  },
  {
   "cell_type": "code",
   "execution_count": 43,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "t6bnZb0xNpId",
    "outputId": "37f06f10-b71a-42bb-b846-736d9ed83763"
   },
   "outputs": [
    {
     "output_type": "stream",
     "name": "stdout",
     "text": [
      "Best Temperature T = 0.7\n",
      "ECE before temperature scaling: 0.0615\n",
      "ECE after  temperature scaling: 0.0740\n"
     ]
    }
   ],
   "source": [
    "def get_logits(model, X):\n",
    "    \"\"\"Return raw logits from the ANN for a NumPy array X.\"\"\"\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        X_tensor = torch.FloatTensor(X).to(device)\n",
    "        logits = model(X_tensor)\n",
    "    return logits.cpu().numpy()\n",
    "\n",
    "def apply_temperature(logits, T):\n",
    "    \"\"\"Scale logits by temperature T and return softmax probabilities.\"\"\"\n",
    "    scaled = logits / T\n",
    "    exp_s  = np.exp(scaled - np.max(scaled, axis=1, keepdims=True))\n",
    "    return exp_s / np.sum(exp_s, axis=1, keepdims=True)\n",
    "\n",
    "# Find best temperature on validation set\n",
    "val_logits = get_logits(model, X_val)\n",
    "best_T, best_nll = 1.0, float(\"inf\")\n",
    "\n",
    "for T in np.arange(0.5, 3.1, 0.1):\n",
    "    probs_T = np.clip(apply_temperature(val_logits, T), 1e-7, 1.0)\n",
    "    nll = -np.mean(np.log(probs_T[np.arange(len(y_val)), y_val.values]))\n",
    "    if nll < best_nll:\n",
    "        best_nll = nll\n",
    "        best_T   = T\n",
    "\n",
    "print(f\"Best Temperature T = {best_T:.1f}\")\n",
    "\n",
    "# Apply to test set\n",
    "test_logits       = get_logits(model, X_test)\n",
    "y_pred_calibrated = apply_temperature(test_logits, best_T)\n",
    "ece_after         = compute_ece(y_test, y_pred_calibrated)\n",
    "\n",
    "print(f\"ECE before temperature scaling: {ece_score:.4f}\")\n",
    "print(f\"ECE after  temperature scaling: {ece_after:.4f}\")"
   ],
   "id": "t6bnZb0xNpId"
  },
