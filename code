   "source": [
    "## Ordinal Penalty Matrix\n",
    "\n",
    "Encodes the cost of misclassifying across the investment-grade cliff (BBB \u2192 BB). A `cliff_factor` of 2.0 doubles the penalty at that boundary."
   ],
   "id": "ilhTsORoNpIb"
  },
  {
   "cell_type": "code",
   "execution_count": 33,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "ZEJVscQWNpIb",
    "outputId": "e7365393-8d79-4a3f-dfd5-7e2414967b65"
   },
   "outputs": [
    {
     "output_type": "stream",
     "name": "stdout",
     "text": [
      "Ordinal Penalty Matrix:\n",
      "        AAA    AA     A   BBB    BB     B\n",
      "  AAA     0     1     2     3     4     5\n",
      "  AA     1     0     1     2     3     4\n",
      "  A     2     1     0     1     2     3\n",
      "  BBB     3     2     1     0     2     2\n",
      "  BB     4     3     2     2     0     1\n",
      "  B     5     4     3     2     1     0\n"
     ]
    }
   ],
   "source": [
    "def build_penalty_matrix(n_classes=6, cliff_factor=2.0):\n",
    "    \"\"\"Build an ordinal penalty matrix with an investment-grade cliff.\"\"\"\n",
    "    W = np.zeros((n_classes, n_classes), dtype=np.float32)\n",
    "    for i in range(n_classes):\n",
    "        for j in range(n_classes):\n",
    "            W[i][j] = abs(i - j)\n",
    "    # Investment-grade cliff: BBB=3, BB=4\n",
    "    W[3][4] = cliff_factor\n",
    "    W[4][3] = cliff_factor\n",
    "    return W\n",
    "\n",
    "PENALTY_MATRIX = build_penalty_matrix()\n",
    "\n",
    "print(\"Ordinal Penalty Matrix:\")\n",
    "header = \"       \" + \"  \".join(f\"{l:>4}\" for l in ordinal_order)\n",
    "print(header)\n",
    "for i, row_label in enumerate(ordinal_order):\n",
    "    row_str = \"  \".join(f\"{v:>4.0f}\" for v in PENALTY_MATRIX[i])\n",
    "    print(f\"  {row_label}  {row_str}\")"
   ],
   "id": "ZEJVscQWNpIb"
  },
