   "source": [
    "## Probability Calibration \u2014 ECE & Reliability Diagram\n",
    "\n",
    "Expected Calibration Error (ECE) measures how well predicted probabilities match true outcome frequencies."
   ],
   "id": "70mfq4mHNpId"
  },
  {
   "cell_type": "code",
   "execution_count": 42,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 513
    },
    "id": "EQhm2X30NpId",
    "outputId": "ebbc7d8d-8f62-4fdc-fce0-0d323625fe9b"
   },
   "outputs": [
    {
     "output_type": "stream",
     "name": "stdout",
     "text": [
      "Expected Calibration Error (ECE): 0.0615\n",
      "(0 = perfect; lower is better)\n"
     ]
    },
    {
     "output_type": "display_data",
     "data": {
      "text/plain": [
       "<Figure size 700x600 with 1 Axes>"
      ],
      "image/png": "\n"
     },
     "metadata": {}
    }
   ],
   "source": [
    "def compute_ece(y_true, y_pred_proba, n_bins=10):\n",
    "    \"\"\"Expected Calibration Error (lower is better).\"\"\"\n",
    "    confidences = np.max(y_pred_proba, axis=1)\n",
    "    predictions = np.argmax(y_pred_proba, axis=1)\n",
    "    correct     = (predictions == np.array(y_true))  # works for both Series and ndarray\n",
    "\n",
    "    bin_edges = np.linspace(0, 1, n_bins + 1)\n",
    "    ece = 0.0\n",
    "    for i in range(n_bins):\n",
    "        lo, hi  = bin_edges[i], bin_edges[i + 1]\n",
    "        in_bin  = (confidences >= lo) & (confidences < hi)\n",
    "        if in_bin.sum() == 0:\n",
    "            continue\n",
    "        bin_acc    = correct[in_bin].mean()\n",
    "        bin_conf   = confidences[in_bin].mean()\n",
    "        bin_weight = in_bin.sum() / len(y_true)\n",
    "        ece += bin_weight * abs(bin_acc - bin_conf)\n",
    "    return ece\n",
    "\n",
    "ece_score = compute_ece(y_test, y_pred_proba)\n",
    "print(f\"Expected Calibration Error (ECE): {ece_score:.4f}\")\n",
    "print(\"(0 = perfect; lower is better)\")\n",
    "\n",
    "# Reliability diagram (one-vs-rest per class)\n",
    "fig, ax = plt.subplots(figsize=(7, 6))\n",
    "for class_idx, class_name in enumerate(ordinal_order):\n",
    "    y_binary = (y_test.values == class_idx).astype(int)\n",
    "    prob_pos = y_pred_proba[:, class_idx]\n",
    "    if y_binary.sum() < 5:\n",
    "        continue\n",
    "    fraction_pos, mean_pred_val = calibration_curve(y_binary, prob_pos, n_bins=8)\n",
    "    ax.plot(mean_pred_val, fraction_pos, marker='o', label=class_name)\n",
    "\n",
    "ax.plot([0, 1], [0, 1], 'k--', label='Perfect calibration')\n",
    "ax.set_title(\"Reliability Diagram (per class, one-vs-rest)\")\n",
    "ax.set_xlabel(\"Mean Predicted Probability\")\n",
    "ax.set_ylabel(\"Fraction of Positives\")\n",
    "ax.legend()\n",
    "ax.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ],
