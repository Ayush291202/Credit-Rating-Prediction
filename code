    "class CreditRatingANN(nn.Module):\n",
    "    def __init__(self, input_dim, n_classes=6):\n",
    "        super(CreditRatingANN, self).__init__()\n",
    "        self.network = nn.Sequential(\n",
    "            # Hidden layer 1\n",
    "            nn.Linear(input_dim, 64),\n",
    "            nn.ReLU(),\n",
    "            nn.BatchNorm1d(64),\n",
    "            nn.Dropout(0.3),\n",
    "            # Hidden layer 2\n",
    "            nn.Linear(64, 32),\n",
    "            nn.ReLU(),\n",
    "            nn.BatchNorm1d(32),\n",
    "            nn.Dropout(0.3),\n",
    "            # Output layer\n",
    "            nn.Linear(32, n_classes)\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        return self.network(x)\n",
    "\n",
    "model = CreditRatingANN(input_dim=X_train_sm.shape[1], n_classes=6).to(device)\n",
    "print(model)"
